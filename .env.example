# LLM auth profiles
DEEPSEEK_API=
KIMI_API_KEY=
KIMI_CODE_API_KEY=
GLM_API_KEY=

# Feishu bot
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_RAW_EVENT_DUMP_ENABLED=1
FEISHU_RAW_EVENT_DUMP_DIR=logs/feishu_raw_events

# Mabang login profiles
MABANG_ACCOUNT=
MABANG_PASSWORD=
MABANG_ACCOUNT_TEMU=
MABANG_PASSWORD_TEMU=

# Mabang artifact directories (optional)
MABANG_STOCK_SKU_EXPORT_DIR=
MABANG_FBA_STORE_RESOLVER_OUTPUT_DIR=
MABANG_STORE_MSKU_OUTPUT_DIR=
MABANG_STORE_MSKU_ANALYSIS_OUTPUT_DIR=
MABANG_STORE_MSKU_INVENTORY_OUTPUT_DIR=
MABANG_STORE_MSKU_REPLENISHMENT_OUTPUT_DIR=
MABANG_MSKU_DETAIL_OUTPUT_DIR=
FBA_DELIVERY_CSV_DIR=

# Ziniao login profile
ZINIAO_COMPANY=
ZINIAO_USERNAME=
ZINIAO_PASSWORD=

# Ziniao machine settings
ZINIAO_CLIENT_PATH=
ZINIAO_WEBDRIVER_PATH=
ZINIAO_BROWSER_VERSION=v6
ZINIAO_SOCKET_PORT=16851

# Logistics API network settings
LOGISTICS_USE_REMOTE_API=1
LOGISTICS_REMOTE_API_BASE_URL=
LOGISTICS_LOCAL_API_BASE_URL=http://127.0.0.1:8000
LOGISTICS_API_TIMEOUT_SECONDS=30
LOGISTICS_IMPORT_POLL_INTERVAL_SECONDS=10
LOGISTICS_IMPORT_MAX_POLLS=6

# Browser auth and WMS export
BROWSER_AUTH_HEADLESS=1
FBA_LOGISTICS_TOKEN_HEADLESS=1
FBA_LOGISTICS_ENABLE_WMS_EXPORT=1
FBA_LOGISTICS_WMS_EXPORT_STRICT=0
FBA_LOGISTICS_WMS_EXPORT_RETRY=1

# Gateway runtime
GATEWAY_ID=
AGENT_MAX_CONCURRENCY=2
GATEWAY_ADAPTER_RECYCLE_ENABLED=1
GATEWAY_ADAPTER_WATCHDOG_ENABLED=1
AGENT_DASHBOARD_OPEN_BROWSER=1

# Telemetry upload (optional, disabled by default)
TELEMETRY_ENABLED=0
TELEMETRY_SERVER_URL=
TELEMETRY_API_KEY=
TELEMETRY_SYNC_INTERVAL_SECONDS=300
TELEMETRY_REQUEST_TIMEOUT_SECONDS=30
TELEMETRY_SESSION_LIMIT=1000

# Agent LLM runtime selection
AGENT_LLM_PROVIDER=kimi_coding
AGENT_LLM_MODEL=kimi-for-coding
AGENT_LLM_MAX_TOKENS=0
KIMI_CODE_THINKING_ENABLED=1
LLM_REQUEST_TIMEOUT_S=120

# Agent stream and trace diagnostics
AGENT_STREAM_LOG_MODE=summary
AGENT_STREAM_TRACE_ENABLED=1
AGENT_STREAM_HEARTBEAT_MS=1000
AGENT_STREAM_HEARTBEAT_CHARS=300
AGENT_STREAM_DEBUG_PREVIEW_CHARS=80
AGENT_STREAM_TRACE_DIR=logs/agent_traces
AGENT_SSE_WIRE_TRACE_ENABLED=1
AGENT_SSE_WIRE_TRACE_DIR=logs/sse_wire_traces
