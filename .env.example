# LLM auth profiles
DEEPSEEK_API=
KIMI_CODE_API_KEY=
GLM_API_KEY=

# Feishu bot
# Set to 0 only for gateway energy diagnostics; normal runtime should keep it enabled.
FEISHU_GATEWAY_ENABLED=1
# Restart only the Feishu WebSocket periodically to avoid long-running SDK state drift.
FEISHU_WS_AUTO_RESTART_ENABLED=1
FEISHU_WS_AUTO_RESTART_INTERVAL_SECONDS=5400
FEISHU_WS_AUTO_RESTART_IDLE_CHECK_SECONDS=30
FEISHU_WS_AUTO_RESTART_RETRY_SECONDS=60
# Required app scopes include im:message.reactions:write_only for Typing indicators.
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BOT_OPEN_ID=

# Mabang login profiles
MABANG_ACCOUNT=
MABANG_PASSWORD=

# Ziniao login profile
ZINIAO_COMPANY=
ZINIAO_USERNAME=
ZINIAO_PASSWORD=

# Gateway private identity
GATEWAY_ID=

# Data server auth
LXE_DATA_SERVER_API_KEY=
